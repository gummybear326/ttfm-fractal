f_c1_liquidity_time(bool bearish, int c1_start, int c1_end) =>
    int result_t = c1_start
    float extreme = bearish ? -10e10 : 10e10
    for i = 0 to 5000
        int ti = time[i]
        if na(ti)
            break
        if ti < c1_start
            break
        if ti >= c1_start and ti < c1_end
            if bearish
                if high[i] > extreme
                    extreme := high[i]
                    result_t := ti
            else
                if low[i] < extreme
                    extreme := low[i]
                    result_t := ti
    result_t


