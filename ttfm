f_cisd_push_event(int dir, int trigger_t, int origin_t, float level) =>
    array.push(cisd_event_dir, dir)
    array.push(cisd_event_time, trigger_t)
    array.push(cisd_event_origin_t, origin_t)
    array.push(cisd_event_level, level)
    if array.size(cisd_event_dir) > 250
        array.shift(cisd_event_dir)
        array.shift(cisd_event_time)
        array.shift(cisd_event_origin_t)
        array.shift(cisd_event_level)

f_cisd_origin_time_from_index(int idx) =>
    int result = time
    int bars_back = bar_index - idx
    if bars_back >= 0 and bars_back <= 5000 and not na(time[bars_back])
        result := time[bars_back]
    result

f_cisd_consult(int bias_dir) =>
    int temporal_shift = 0
    float extreme = open[0]
    int candle_attitude = close[0] > open[0] ? 1 : close[0] < open[0] ? -1 : 0
    if candle_attitude == 0 or candle_attitude != bias_dir
        [extreme, bar_index]
    else
        for i = 1 to 500
            candle_attitude := close[i] > open[i] ? 1 : close[i] < open[i] ? -1 : 0
            if candle_attitude == 0
                continue
            bool mood_match = candle_attitude == bias_dir
            if not mood_match
                break
            temporal_shift := i
            if bias_dir == 1
                if open[i] < extreme
                    extreme := open[i]
            else
                if open[i] > extreme
                    extreme := open[i]
        int extreme_shift = na
        for k = 0 to temporal_shift
            if open[k] == extreme
                extreme_shift := k
                break
        [extreme, bar_index - extreme_shift]

f_cisd_archaeologist(int bias_dir) =>
    int i = 1
    bool artifact_found = false
    int max_shift = na
    float extreme = na
    for j = 1 to 500
        i := j
        int candle_attitude = close[i] > open[i] ? 1 : close[i] < open[i] ? -1 : 0
        if candle_attitude == 0
            continue
        bool is_correct_era = candle_attitude == bias_dir
        if not artifact_found
            if is_correct_era
                artifact_found := true
                max_shift := i
                extreme := open[i]
        else
            if not is_correct_era
                break
            max_shift := i
            if bias_dir == 1
                if open[i] < extreme
                    extreme := open[i]
            else
                if open[i] > extreme
                    extreme := open[i]
    int extreme_shift = na
    if not na(max_shift)
        for k = 1 to max_shift
            if open[k] == extreme
                extreme_shift := k
                break
    [extreme, bar_index - extreme_shift]

