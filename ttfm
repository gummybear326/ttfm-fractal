        array.push(labels, label.new(x, y, txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.black, 100), textcolor=projection_color, size=size.tiny))

f_projection_structure_anchor(bool bearish, int c2_start_t, int c2_end_t, float c2_extreme) =>
    float anchor = na
    int anchor_t = na
    int extreme_t = na
    int search_start_t = c2_start_t - htf_ms

    for k = 0 to 5000
        int kt = time[k]
        if na(kt)
            break
        if kt < c2_start_t
            break
        if kt >= c2_start_t and kt < c2_end_t
            bool is_extreme_bar = bearish ? high[k] >= c2_extreme : low[k] <= c2_extreme
            if is_extreme_bar
                extreme_t := kt
                break

    if not na(extreme_t)
        for k = 1 to 4999
            int kt = time[k]
            if na(kt) or na(time[k + 1]) or na(time[k - 1])
                break
            if kt < search_start_t
                break
            if kt >= search_start_t and kt < extreme_t
                bool swing_low = low[k] < low[k + 1] and low[k] < low[k - 1]
                bool swing_high = high[k] > high[k + 1] and high[k] > high[k - 1]
                if bearish and swing_low
                    anchor := low[k]
                    anchor_t := kt
                    break
                if not bearish and swing_high
                    anchor := high[k]
                    anchor_t := kt
                    break

    [anchor, anchor_t, extreme_t]

f_draw_projections(bool bearish, int anchor_t, int extreme_t, float c2_extreme, float structure_anchor) =>
    if show_projections and not na(c2_extreme) and not na(structure_anchor) and not na(anchor_t) and not na(extreme_t)
        string[] parts = str.split(projection_levels, ",")
        int count = array.size(parts)
        if count > 0
            float proj_range = math.abs(c2_extreme - structure_anchor)
            int marker_x1 = math.min(anchor_t, extreme_t)
            int marker_x2 = math.max(anchor_t, extreme_t)
            if marker_x1 == marker_x2
                marker_x2 += tf_sec * 1000
            for pi = 0 to count - 1
                string raw = str.trim(array.get(parts, pi))
                float lvl = str.tonumber(raw)
                if not na(lvl)
                    float price = lvl == 1 ? c2_extreme : lvl == 0 ? structure_anchor : bearish ? structure_anchor - proj_range * math.abs(lvl) : structure_anchor + proj_range * math.abs(lvl)
                    array.push(lines, line.new(marker_x1, price, marker_x2, price, xloc=xloc.bar_time, color=projection_color, width=projection_width, style=f_style(projection_style)))
                    f_draw_projection_label(marker_x2, price, raw)

