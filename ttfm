// ============================================================
// HELPERS
// ============================================================
f_style(string s) =>
    s == "Dashed" ? line.style_dashed : s == "Dotted" ? line.style_dotted : line.style_solid

f_tf_label(string tf) =>
    int sec = timeframe.in_seconds(tf)
    sec < 3600 ? str.tostring(math.round(sec / 60)) + "m" :
     sec < 86400 and sec % 3600 != 0 ? str.tostring(math.round(sec / 60)) + "m" :
     sec < 86400 ? str.tostring(math.round(sec / 3600)) + "H" :
     sec == 86400 ? "1D" : sec == 604800 ? "1W" : tf

f_mid_time(int t, int ms) =>
    t + math.round(ms / 2)

f_pad2(int n) =>
    n < 10 ? "0" + str.tostring(n) : str.tostring(n)

f_countdown_string(int close_t) =>
    int seconds_left = math.max(0, math.round((close_t - timenow) / 1000))
    int hh = math.floor(seconds_left / 3600)
    int mm = math.floor((seconds_left % 3600) / 60)
    int ss = seconds_left % 60
    f_pad2(hh) + ":" + f_pad2(mm) + ":" + f_pad2(ss)

f_date_string(int t) =>
    f_pad2(month(t)) + "/" + f_pad2(dayofmonth(t)) + "/" + f_pad2(year(t) % 100)

f_table_position(string p) =>
    p == "Top Right" ? position.top_right :
     p == "Top Left" ? position.top_left :
     p == "Bottom Left" ? position.bottom_left :
     p == "Top Center" ? position.top_center :
     p == "Bottom Center" ? position.bottom_center : position.bottom_right

