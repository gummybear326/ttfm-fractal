    int first_impression = close > open ? 1 : close < open ? -1 : 0
    if first_impression == 0
        for k = 1 to 50
            first_impression := close[k] > open[k] ? 1 : close[k] < open[k] ? -1 : 0
            if first_impression != 0
                break
    if first_impression != 0
        cisd_vibes := first_impression
        [origin_price, origin_idx] = f_cisd_consult(first_impression)
        cisd_bagholder_entry  := origin_price
        cisd_time_machine_idx := origin_idx
        cisd_pain_threshold   := first_impression == 1 ? high : low

int cisd_candle_personality = close > open ? 1 : close < open ? -1 : 0
float cisd_fresh_hopium = na
int cisd_fresh_timestamp = na

if cisd_engine_on and cisd_vibes == 1
    if high > cisd_pain_threshold
        cisd_pain_threshold := high
        if cisd_candle_personality == 1
            [p_price, p_idx] = f_cisd_consult(1)
            cisd_fresh_hopium := p_price
            cisd_fresh_timestamp := p_idx
        else
            [p_price, p_idx] = f_cisd_archaeologist(1)
            cisd_fresh_hopium := p_price
            cisd_fresh_timestamp := p_idx
        cisd_bagholder_entry  := cisd_fresh_hopium
        cisd_time_machine_idx := cisd_fresh_timestamp
else if cisd_engine_on and cisd_vibes == -1
    if low < cisd_pain_threshold
        cisd_pain_threshold := low
        if cisd_candle_personality == -1
            [p_price, p_idx] = f_cisd_consult(-1)
            cisd_fresh_hopium := p_price
            cisd_fresh_timestamp := p_idx
        else
            [p_price, p_idx] = f_cisd_archaeologist(-1)
            cisd_fresh_hopium := p_price
            cisd_fresh_timestamp := p_idx
        cisd_bagholder_entry  := cisd_fresh_hopium
        cisd_time_machine_idx := cisd_fresh_timestamp

bool cisd_bull_trigger = cisd_engine_on and cisd_vibes == -1 and close > cisd_bagholder_entry
bool cisd_bear_trigger = cisd_engine_on and cisd_vibes ==  1 and close < cisd_bagholder_entry

if cisd_bull_trigger or cisd_bear_trigger
    int new_state = cisd_bull_trigger ? 1 : -1
    int origin_t = f_cisd_origin_time_from_index(cisd_time_machine_idx)
    f_cisd_push_event(new_state, time, origin_t, cisd_bagholder_entry)

    cisd_vibes := new_state
    [reset_price, reset_idx] = f_cisd_consult(new_state)
    cisd_bagholder_entry  := reset_price
    cisd_time_machine_idx := reset_idx
    cisd_pain_threshold   := new_state == 1 ? high : low

f_has_cisd(bool bearish, int start_t, int end_t) =>
    bool found = false
    int wanted_dir = bearish ? -1 : 1
    int sz = array.size(cisd_event_dir)
    if sz > 0
        for n = 0 to sz - 1
            int j = sz - 1 - n
            int dir = array.get(cisd_event_dir, j)
            int t = array.get(cisd_event_time, j)
            if dir == wanted_dir and t >= start_t and t < end_t
                found := true
                break
    found

