f_draw_tspot(bool bearish, int src_t, float src_h, float src_l, float src_c) =>
    if show_tspot and not na(src_t) and not na(src_h) and not na(src_l) and not na(src_c)
        int x1 = src_t + htf_ms
        int x2 = src_t + htf_ms * 2
        float top = na
        float bot = na
        if bearish
            float mid = (src_h + src_c) / 2.0
            top := mid
            bot := src_c
        else
            float mid = (src_c + src_l) / 2.0
            top := src_c
            bot := mid
        if not na(top) and not na(bot) and top != bot
            array.push(boxes, box.new(x1, math.max(top, bot), x2, math.min(top, bot), xloc=xloc.bar_time, bgcolor=bearish ? tspot_bear_color : tspot_bull_color, border_color=bearish ? tspot_bear_color : tspot_bull_color, border_width=tspot_border_width))

f_wick_eq_price(bool bearish, float o, float h, float l, float c) =>
    float eq = na
    if not na(o) and not na(h) and not na(l) and not na(c)
        float body = math.abs(c - o)
        float min_body = math.max(body, syminfo.mintick)
        float wick_top = na
        float wick_bot = na
        float wick_size = na
        if bearish
            wick_top := h
            wick_bot := math.max(o, c)
            wick_size := wick_top - wick_bot
        else
            wick_top := math.min(o, c)
            wick_bot := l
            wick_size := wick_top - wick_bot
        if wick_size >= min_body * 0.40
            eq := (wick_top + wick_bot) / 2.0
    eq

f_draw_eq_projected(bool bearish, int htf_idx, float o, float h, float l, float c, int base_x_, int num_, int step_, int half_) =>
    float eq = f_wick_eq_price(bearish, o, h, l, c)
    if show_eq and not na(eq)
        int x_mid = base_x_ + (num_ - 1 - htf_idx) * step_
        int x_left = x_mid - half_
        int x_right = x_mid + half_
        array.push(lines, line.new(x_left, eq, x_right, eq, xloc=xloc.bar_index, color=eq_color, width=eq_width, style=f_style(eq_style)))

f_opposite_model_at_index(bool current_bearish, int idx) =>
    bool found = false
    int ref_idx = idx + 1
    if idx >= 0 and ref_idx < array.size(arr_h)
        float rh = array.get(arr_h, ref_idx)
        float rl = array.get(arr_l, ref_idx)
        float ch = array.get(arr_h, idx)
        float cl = array.get(arr_l, idx)
        float cc = array.get(arr_c, idx)
        bool ok = not na(rh) and not na(rl) and not na(ch) and not na(cl) and not na(cc)
        if ok
            found := current_bearish ? (cl < rl and cc > rl) : (ch > rh and cc < rh)
    found


f_draw_first_presented_fvg(int htf_start_t, int htf_end_t) =>
    if show_first_presented_fvg and not na(htf_start_t) and not na(htf_end_t)
        bool found = false
        bool bull_fvg = false
        float top = na
        float bot = na
        int left_t = na
        int right_t = htf_end_t - 1

        // Scan chart-timeframe candles from oldest to newest inside this HTF candle.
        // The FVG must be fully presented inside the HTF candle, so the left candle
        // of the 3-candle FVG structure must also be inside this HTF window.
        for k = 5000 to 0
            if found
                break
            int kt = time[k]
            if na(kt)
                continue
            if k + 2 > 5000 or na(time[k + 2]) or na(high[k + 2]) or na(low[k + 2]) or na(high[k]) or na(low[k])
                continue
            int left_candidate_t = time[k + 2]
            bool inside_window = left_candidate_t >= htf_start_t and kt >= htf_start_t and kt < htf_end_t
            if inside_window
                bool is_bull_fvg = low[k] > high[k + 2]
                bool is_bear_fvg = high[k] < low[k + 2]
                if is_bull_fvg or is_bear_fvg
                    found := true
                    bull_fvg := is_bull_fvg
                    top := is_bull_fvg ? low[k] : low[k + 2]
                    bot := is_bull_fvg ? high[k + 2] : high[k]
                    left_t := left_candidate_t

        if found and not na(left_t) and not na(top) and not na(bot)
            color fill_col = bull_fvg ? first_fvg_bull_fill : first_fvg_bear_fill
            color border_col = bull_fvg ? first_fvg_bull_border : first_fvg_bear_border
            array.push(boxes, box.new(left_t, math.max(top, bot), right_t, math.min(top, bot), xloc=xloc.bar_time, bgcolor=fill_col, border_color=border_col, border_width=first_fvg_border_width))
            if first_fvg_show_label
                string txt = bull_fvg ? "First Bull FVG" : "First Bear FVG"
                array.push(labels, label.new(right_t, (top + bot) / 2.0, txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.black, 100), textcolor=first_fvg_label_color, size=model_label_size))

// ============================================================
// MAIN DRAWING
// ============================================================
if barstate.islast
    f_clear()

    int num = math.min(htf_candles, 20)
    int candle_w = htf_size == "Large" ? 5 : htf_size == "Medium" ? 3 : 1
    int step = candle_w + 2
    int base_x = bar_index + htf_offset + 8
    int half = math.max(1, math.round(candle_w / 2))

    // HTF projected candles
    if not hide_htf_candles
        for i = 0 to num - 1
            float o = array.get(arr_o, i)
            float h = array.get(arr_h, i)
            float l = array.get(arr_l, i)
            float c = array.get(arr_c, i)
            int t = array.get(arr_t, i)
            if na(o) or na(h) or na(l) or na(c) or na(t)
                continue
            bool bull = c >= o
            int x = base_x + (num - 1 - i) * step
            int xl = x - half
            int xr = x + half
            float body_top = math.max(o, c)
            float body_bot = math.min(o, c)
            if body_top == body_bot
                body_top += syminfo.mintick
            array.push(boxes, box.new(xl, body_top, xr, body_bot, xloc=xloc.bar_index, bgcolor=bull ? bull_body : bear_body, border_color=bull ? bull_border : bear_border, border_width=1))
            array.push(lines, line.new(x, h, x, body_top, xloc=xloc.bar_index, color=bull ? bull_wick : bear_wick, width=1))
            array.push(lines, line.new(x, body_bot, x, l, xloc=xloc.bar_index, color=bull ? bull_wick : bear_wick, width=1))
            if show_htf_open and i == 0
                array.push(lines, line.new(t, o, time, o, xloc=xloc.bar_time, color=htf_open_color, style=f_style(htf_open_style), width=htf_open_width))
                array.push(lines, line.new(bar_index, o, x + half, o, xloc=xloc.bar_index, color=htf_open_color, style=f_style(htf_open_style), width=htf_open_width))
            if show_oc_time
                array.push(lines, line.new(t, l, t, h, xloc=xloc.bar_time, extend=extend.both, color=oc_color, style=f_style(oc_style), width=oc_width))
            if show_lh_lines
                array.push(lines, line.new(t, h, t + htf_ms, h, xloc=xloc.bar_time, color=lh_color, style=f_style(lh_style), width=lh_width))
                array.push(lines, line.new(t, l, t + htf_ms, l, xloc=xloc.bar_time, color=lh_color, style=f_style(lh_style), width=lh_width))

    // First Presented FVG for each active HTF candle
    if show_first_presented_fvg
        for i = 0 to num - 1
            int fvg_htf_start = array.get(arr_t, i)
            if not na(fvg_htf_start)
                f_draw_first_presented_fvg(fvg_htf_start, fvg_htf_start + htf_ms)

    // Models
    int setups_drawn = 0
    int max_models = history + 1
    int scan_limit = math.min(num - 1, 18)

    for c2_idx = 1 to scan_limit
        if setups_drawn >= max_models
            break

        int c1_idx = c2_idx + 1
        int c3_idx = c2_idx - 1
        int c4_idx = c2_idx - 2

        float c1h = array.get(arr_h, c1_idx)
        float c1l = array.get(arr_l, c1_idx)
        int c1t = array.get(arr_t, c1_idx)
        float c2o = array.get(arr_o, c2_idx)
        float c2h = array.get(arr_h, c2_idx)
        float c2l = array.get(arr_l, c2_idx)
        float c2c = array.get(arr_c, c2_idx)
        int c2t = array.get(arr_t, c2_idx)

        bool data_ok = not na(c1h) and not na(c1l) and not na(c1t) and not na(c2o) and not na(c2h) and not na(c2l) and not na(c2c) and not na(c2t)
        if not data_ok
            continue

        bool bear_setup = c2h > c1h and c2c <= c1h
        bool bull_setup = c2l < c1l and c2c >= c1l
        int dir = bear_setup ? -1 : bull_setup ? 1 : 0
        if dir == 0
            continue

        bool bearish = dir == -1
        bool display_model = bias == "Neutral" or (bias == "Bearish" and bearish) or (bias == "Bullish" and not bearish)
        int c2_end = c2t + htf_ms
        int c3_end = c2_end + htf_ms
        bool cisd_ok = not require_cisd or f_has_cisd(bearish, c2t, math.min(time + tf_sec * 1000, c3_end))
        if not cisd_ok
            continue

        if not display_model
            continue

        bool fail_c3 = false
        bool fail_c4 = false
        if c3_idx >= 0
            float c3h = array.get(arr_h, c3_idx)
            float c3l = array.get(arr_l, c3_idx)
            bool level_fail_c3 = bearish ? c3h > c2h : c3l < c2l
            bool opposite_fail_c3 = c3_idx >= 1 ? f_opposite_model_at_index(bearish, c3_idx) : false
            fail_c3 := level_fail_c3 or opposite_fail_c3
        if not fail_c3 and c4_idx >= 0 and c3_idx >= 0
            float c3h_for_fail = array.get(arr_h, c3_idx)
            float c3l_for_fail = array.get(arr_l, c3_idx)
            float c4h = array.get(arr_h, c4_idx)
            float c4l = array.get(arr_l, c4_idx)
            bool level_fail_c4 = bearish ? c4h > c3h_for_fail : c4l < c3l_for_fail
            bool opposite_fail_c4 = c4_idx >= 1 ? f_opposite_model_at_index(bearish, c4_idx) : false
            fail_c4 := level_fail_c4 or opposite_fail_c4

        color state_col = fail_c3 ? fail_c3_color : fail_c4 ? fail_c4_color : valid_color
        bool show_follow_through = not fail_c3

        float sweep_price = bearish ? c1h : c1l
        int liq_t = f_c1_liquidity_time(bearish, c1t, c1t + htf_ms)
        bool keep_c2_sweep = not fail_c3 and not fail_c4
        if show_c1_sweep and keep_c2_sweep
            array.push(lines, line.new(liq_t, sweep_price, c2_end, sweep_price, xloc=xloc.bar_time, color=c1_sweep_color, width=c1_sweep_width, style=f_style(c1_sweep_style)))
            int c1x = base_x + (num - 1 - c1_idx) * step
            int c2x = base_x + (num - 1 - c2_idx) * step
            array.push(lines, line.new(c1x, sweep_price, c2x + step, sweep_price, xloc=xloc.bar_index, color=c1_sweep_color, width=c1_sweep_width, style=f_style(c1_sweep_style)))

        f_draw_eq_projected(bearish, c2_idx, c2o, c2h, c2l, c2c, base_x, num, step, half)
        if show_follow_through and c3_idx >= 0
            f_draw_eq_projected(bearish, c3_idx, array.get(arr_o, c3_idx), array.get(arr_h, c3_idx), array.get(arr_l, c3_idx), array.get(arr_c, c3_idx), base_x, num, step, half)
        if show_follow_through and c4_idx >= 0
            f_draw_eq_projected(bearish, c4_idx, array.get(arr_o, c4_idx), array.get(arr_h, c4_idx), array.get(arr_l, c4_idx), array.get(arr_c, c4_idx), base_x, num, step, half)

        float c2_projection_anchor = bearish ? c2h : c2l
        [projection_zero_anchor, projection_zero_time, projection_one_time] = f_projection_structure_anchor(bearish, c2t, c2_end, c2_projection_anchor)
        if show_follow_through
            f_draw_projections(bearish, projection_zero_time, projection_one_time, c2_projection_anchor, projection_zero_anchor)

        f_draw_tspot(bearish, c2t, c2h, c2l, c2c)
        if show_follow_through and c3_idx >= 1
            f_draw_tspot(bearish, array.get(arr_t, c3_idx), array.get(arr_h, c3_idx), array.get(arr_l, c3_idx), array.get(arr_c, c3_idx))
        if show_follow_through and c4_idx >= 1
            f_draw_tspot(bearish, array.get(arr_t, c4_idx), array.get(arr_h, c4_idx), array.get(arr_l, c4_idx), array.get(arr_c, c4_idx))

        if show_model_labels
            if show_c2
                f_label(f_mid_time(c2t, htf_ms), bearish ? c2h : c2l, "C2", state_col, true)
            if show_follow_through and show_c3 and c3_idx >= 0
                int c3t = array.get(arr_t, c3_idx)
                float c3h = array.get(arr_h, c3_idx)
                float c3l = array.get(arr_l, c3_idx)
                f_label(f_mid_time(c3t, htf_ms), bearish ? c3h : c3l, "C3", state_col, true)
            if show_follow_through and show_c4 and c4_idx >= 0
                int c4t = array.get(arr_t, c4_idx)
                float c4h = array.get(arr_h, c4_idx)
                float c4l = array.get(arr_l, c4_idx)
                f_label(f_mid_time(c4t, htf_ms), bearish ? c4h : c4l, "C4", state_col, true)

        setups_drawn += 1

    // Global CISD lines
    int cisd_drawn = 0
    int cisd_sz = array.size(cisd_event_dir)
    int cisd_extend_ms = timeframe.in_seconds(timeframe.period) * 1000 * cisd_extend_bars
    if cisd_sz > 0
        for n = 0 to cisd_sz - 1
            if cisd_drawn >= cisd_show_count
                break
            int j = cisd_sz - 1 - n
            int dir = array.get(cisd_event_dir, j)
            bool show_event = dir == 1 ? show_bull_cisd : show_bear_cisd
            if show_event
                int x1 = array.get(cisd_event_origin_t, j)
                int x2_base = array.get(cisd_event_time, j)
                int x2 = x2_base + cisd_extend_ms
                float lvl = array.get(cisd_event_level, j)
                if not na(x1) and not na(x2_base) and not na(lvl)
                    array.push(lines, line.new(x1, lvl, x2, lvl, xloc=xloc.bar_time, color=dir == 1 ? bull_cisd_color : bear_cisd_color, width=dir == 1 ? bull_cisd_width : bear_cisd_width, style=f_style(dir == 1 ? bull_cisd_style : bear_cisd_style)))
                    cisd_drawn += 1

    // Info watermark
    if show_info_table
        if na(info_tbl)
            info_tbl := table.new(
                 f_table_position(table_pos),
                 1,
                 1,
                 bgcolor=table_bg_color,
                 frame_width=0,
                 border_width=0)

        string tf_row = f_tf_label(timeframe.period) + " / " + f_tf_label(htf)
        string countdown_row = f_countdown_string(t0 + htf_ms)
        string date_row = f_date_string(timenow)
        string info_text = str.format("{0}\n{1}\n{2}\n{3}\n{4}", syminfo.ticker, tf_row, bias, countdown_row, date_row)

        table.cell(
             info_tbl,
             0,
             0,
             info_text,
             text_size=table_size,
             text_halign=text.align_center,
             text_valign=text.align_center,
             text_color=table_text_color,
             bgcolor=table_bg_color)

